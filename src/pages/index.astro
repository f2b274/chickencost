<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Chicken Cost - All-American Diagnostic</title>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'barn-red': '#A52A2A',
                        'bright-red': '#D00000',
                        'grass-green': '#2D5A27',
                        'emerald-farm': '#388E3C',
                        'coal': '#121212'
                    },
                    animation: {
                        'vibrant-pulse': 'vibrant-pulse 1.5s infinite',
                    },
                    keyframes: {
                        'vibrant-pulse': {
                            '0%, 100%': { transform: 'scale(1)', boxShadow: '0 0 0 0 rgba(208, 0, 0, 0.4)' },
                            '50%': { transform: 'scale(1.03)', boxShadow: '0 0 20px 10px rgba(208, 0, 0, 0)' },
                        }
                    }
                }
            }
        }
    </script>
    <style>
        body {
            background-image: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)), url('https://images.pexels.com/photos/235725/pexels-photo-235725.jpeg?auto=compress&cs=tinysrgb&w=1260&h=750&dpr=2');
            background-size: cover;
            background-position: center;
            background-attachment: fixed;
        }
        .main-card {
            background: linear-gradient(to bottom, #ffffff, #fcfcfc);
            border: 6px solid #A52A2A;
        }
        .btn-red { background: linear-gradient(135deg, #A52A2A, #D00000); }
        .btn-green { background: linear-gradient(135deg, #2D5A27, #388E3C); }
        .btn-black { background: linear-gradient(135deg, #1A1A1A, #333333); }
    </style>
</head>
<body class="text-coal font-sans antialiased">

    <div x-data="{
        state: 'Select State',
        birds: 5,
        feedCost: 20,
        eggsPerWeek: 20,
        pricePerDozen: 5,
        states: ['Alabama','Alaska','Arizona','Arkansas','California','Colorado','Connecticut','Delaware','Florida','Georgia','Hawaii','Idaho','Illinois','Indiana','Iowa','Kansas','Kentucky','Louisiana','Maine','Maryland','Massachusetts','Michigan','Minnesota','Mississippi','Missouri','Montana','Nebraska','Nevada','New Hampshire','New Jersey','New Mexico','New York','North Carolina','North Dakota','Ohio','Oklahoma','Oregon','Pennsylvania','Rhode Island','South Carolina','South Dakota','Tennessee','Texas','Utah','Vermont','Virginia','Washington','West Virginia','Wisconsin','Wyoming'],
        get monthlyIncome() {
            return ((this.eggsPerWeek * 4) / 12 * this.pricePerDozen);
        },
        get monthlyProfit() {
            return (this.monthlyIncome - this.feedCost);
        },
        get breakingEven() {
            return this.monthlyProfit >= 0;
        }
    }" class="container mx-auto p-4 md:p-12 min-h-screen flex flex-col items-center">

        <div class="text-center mb-8">
            <h1 class="text-6xl md:text-8xl font-black text-white drop-shadow-[0_8px_8px_rgba(0,0,0,0.9)] uppercase italic tracking-tighter">
                CHICKEN <span class="text-bright-red">COST</span>
            </h1>
            <p class="bg-bright-red text-white inline-block px-4 py-1 font-black uppercase text-sm mt-2 skew-x-[-10deg]">
                50-State Profitability Tracker
            </p>
        </div>

        <div class="main-card p-8 md:p-10 rounded-2xl shadow-2xl max-w-2xl w-full">
            
            <div class="mb-6">
                <label class="font-black text-[10px] uppercase text-barn-red block mb-2 tracking-widest text-center">Select Your Location</label>
                <select x-model="state" class="w-full p-3 border-2 border-barn-red rounded font-bold text-center bg-white shadow-sm appearance-none cursor-pointer">
                    <option>Select State</option>
                    <template x-for="s in states" :key="s">
                        <option x-text="s"></option>
                    </template>
                </select>
            </div>

            <div class="grid grid-cols-2 gap-4 mb-8">
                <div class="bg-gray-100 p-3 rounded border-l-4 border-barn-red">
                    <label class="font-black text-[10px] uppercase text-gray-500 block mb-1">Flock Size</label>
                    <input type="number" x-model="birds" class="text-2xl font-black bg-transparent w-full focus:outline-none">
                </div>
                <div class="bg-gray-100 p-3 rounded border-l-4 border-barn-red">
                    <label class="font-black text-[10px] uppercase text-gray-500 block mb-1">Feed Bill ($)</label>
                    <input type="number" x-model="feedCost" class="text-2xl font-black bg-transparent w-full focus:outline-none">
                </div>
                <div class="bg-gray-100 p-3 rounded border-l-4 border-barn-red">
                    <label class="font-black text-[10px] uppercase text-gray-500 block mb-1">Weekly Yield</label>
                    <input type="number" x-model="eggsPerWeek" class="text-2xl font-black bg-transparent w-full focus:outline-none">
                </div>
                <div class="bg-gray-100 p-3 rounded border-l-4 border-barn-red">
                    <label class="font-black text-[10px] uppercase text-gray-500 block mb-1">Price / Doz ($)</label>
                    <input type="number" x-model="pricePerDozen" class="text-2xl font-black bg-transparent w-full focus:outline-none">
                </div>
            </div>

            <div class="text-center p-8 rounded-xl border-4 mb-8 transform transition-all flex flex-col items-center justify-center"
                 :class="breakingEven ? 'bg-green-50 border-grass-green shadow-lg' : 'bg-red-50 border-bright-red shadow-lg'">
                <p class="font-black text-xs uppercase mb-1 tracking-[0.2em]" :class="breakingEven ? 'text-grass-green' : 'text-bright-red'">
                    Monthly Flock ROI
                </p>
                <div class="text-7xl font-black tracking-tighter w-full text-center" x-text="`$${monthlyProfit.toFixed(2)}`"></div>
                <div class="mt-4 font-bold italic w-full text-center" :class="breakingEven ? 'text-grass-green' : 'text-barn-red'">
                    <span x-show="breakingEven">✔ PROFITABLE OPERATION</span>
                    <span x-show="!breakingEven">✘ LEAKING REVENUE</span>
                </div>
            </div>

            <div class="space-y-4">
                <p class="font-black text-center uppercase text-barn-red text-[10px] tracking-widest mb-2 italic">Recommended Steps for <span x-text="state === 'Select State' ? 'Your Flock' : state"></span>:</p>
                
                <template x-if="!breakingEven">
                    <a href="#" class="animate-vibrant-pulse flex items-center justify-between btn-red text-white p-5 rounded-lg shadow-xl hover:scale-[1.02] transition-all">
                        <div>
                            <p class="font-black uppercase text-lg leading-tight">🛑 RED ALERT: Stop the Leak</p>
                            <p class="text-xs font-bold opacity-90">Cut feed costs by 20% immediately.</p>
                        </div>
                        <span class="text-3xl font-black">➔</span>
                    </a>
                </template>

                <template x-if="breakingEven">
                    <a href="#" class="flex items-center justify-between btn-green text-white p-5 rounded-lg shadow-xl hover:scale-[1.02] transition-all">
                        <div>
                            <p class="font-black uppercase text-lg leading-tight">🥚 BOOST: Optimize Your Yield</p>
                            <p class="text-xs font-bold opacity-90">Maximize output based on your state's climate.</p>
                        </div>
                        <span class="text-3xl font-black">➔</span>
                    </a>
                </template>

                <a href="#" class="flex items-center justify-between btn-black text-white p-5 rounded-lg shadow-xl hover:scale-[1.02] transition-all border-b-4 border-bright-red">
                    <div>
                        <p class="font-black uppercase text-lg leading-tight">💎 ELITE: <span x-text="state === 'Select State' ? '' : state"></span> Club</p>
                        <p class="text-xs font-bold opacity-90 italic underline">Unlock Location-Specific ROI Secrets ($19/mo)</p>
                    </div>
                    <span class="text-3xl font-black">➔</span>
                </a>
            </div>

        </div>
    </div>

</body>
</html>
